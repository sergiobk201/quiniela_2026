# Supabase — https://supabase.com/dashboard/project/<project-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Used by Supabase Edge Function (compute-scores)
SUPABASE_URL=https://<project-ref>.supabase.co

# Site URL — no trailing slash (used in auth redirect + invite emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_<key>

# Admin notification email — receives invite requests from the login page
ADMIN_NOTIFICATION_EMAIL=you@example.com
